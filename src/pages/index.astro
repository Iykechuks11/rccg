---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Vision from '../components/Vision.astro';  // Add this import
import WorshipGallery from '../components/WorshipGallery.astro';
import LocationMap from '../components/LocationMap.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import ScriptureVerseImage from '../components/ScriptureVerseImage.astro';
import Icon from '../components/Icon.astro';
import Image from 'astro/components/Image.astro';
import rccg_1 from '../assets/rccg_1.jpg'
import { translations } from '../i18n/translations';

const lang = 'en';
const t = translations[lang];
const churchName = t.churchName;
---

<Layout title="Home - RCCG Love Assembly Macedonia" lang={lang}>
  <!-- Hero Section with RCCG Colors -->
  <Hero lang={lang} churchName={churchName} />

  <!-- Welcome Section -->
  <section class="welcome-section" id="about">
    <div class="container">
      <div class="welcome-grid">
        <div class="welcome-content">
          <div class="section-tag">
            <span class="rccg-tag">RCCG</span>
            <span class="region-tag">Balkan Region</span>
            <span class="country-tag">🇲🇰 North Macedonia</span>
          </div>
          <h2>{lang === 'en' ? 'Welcome to' : 'Добредојдовте во'} <span class="highlight">{churchName}</span></h2>
          <p class="welcome-text">
            {lang === 'en' 
              ? 'We are a parish of the Redeemed Christian Church of God located in the heart of Skopje, North Macedonia. As part of the global RCCG family, we are committed to making heaven and taking as many people as possible with us.'
              : 'Ние сме парохија на Искупената Христијанска Црква Божја, лоцирана во срцето на Скопје, Северна Македонија. Како дел од глобалното RCCG семејство, посветени сме да стигнеме до рајот и да земеме што повеќе луѓе со нас.'}
          </p>
          
          <div class="rccg-values">
            <div class="value-item">
              <span class="value-icon"><Icon name="cross" size={24} /></span>
              <span>{lang === 'en' ? 'Making Heaven' : 'Кон рајот'}</span>
            </div>
            <div class="value-item">
              <span class="value-icon"><Icon name="hands" size={24} /></span>
              <span>{lang === 'en' ? 'Fervent Prayer' : 'Усрдна молитва'}</span>
            </div>
            <div class="value-item">
              <span class="value-icon"><Icon name="book" size={24} /></span>
              <span>{lang === 'en' ? 'Word-Based' : 'Засновано на Словото'}</span>
            </div>
            <div class="value-item">
              <span class="value-icon"><Icon name="heart" size={24} /></span>
              <span>{lang === 'en' ? 'Love Assembly' : 'Собрание на љубов'}</span>
            </div>
          </div>
        </div>
        
        <div class="welcome-image">
          <Image src={rccg_1} 
            alt="RCCG Love Assembly Church"
            class="featured-image"
          />
          <div class="image-overlay-badge">
            <span class="badge-text">{churchName}</span>
            <span class="badge-location">DSC DIZAJN dooel - Skopje</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Vision Section -->
  <Vision lang={lang} />

  <!-- Service Times with RCCG Cards -->
  <section class="services-section" id="services" style="background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%)">
    <div class="container">
      <div class="section-header">
        <span class="section-icon"><Icon name="clock" size={40} /></span>
        <h2>{t.serviceTimes}</h2>
        <p class="section-subtitle">
          {lang === 'en' 
            ? 'Join us for worship, prayer, and fellowship' 
            : 'Придружете ни се за богослужение, молитва и заедништво'}
        </p>
      </div>

      <div class="service-grid">
        <!-- Sunday School -->
        <div class="service-card sunday">
          <div class="card-header" style="background: #d30c07">
            <span class="day-icon"><Icon name="book" size={20} /></span>
            <h3>{t.sundaySchool}</h3>
          </div>
          <div class="card-body">
            <div class="time-badge" style="color: #d30c07">
              <span class="time-icon"><Icon name="clock" size={16} /></span>
              <span class="time">{t.sundaySchoolTime}</span>
            </div>
            <p class="service-desc">{t.sundaySchoolDesc}</p>
            <div class="service-features">
              <span><Icon name="book" size={16} /> Bible Teaching</span>
              <span><Icon name="users" size={16} /> All Ages</span>
              <span><Icon name="target" size={16} /> Discipleship</span>
            </div>
          </div>
          <div class="card-footer">
            <a href="#location" class="btn-service"><Icon name="map-pin" size={16} /> {lang === 'en' ? 'Find Location' : 'Локација'}</a>
          </div>
        </div>

        <!-- Sunday Worship Service -->
        <div class="service-card sunday">
          <div class="card-header" style="background: #26146d">
            <span class="day-icon"><Icon name="cross" size={20} /></span>
            <h3>{t.sundayService}</h3>
          </div>
          <div class="card-body">
            <div class="time-badge" style="color: #d30c07">
              <span class="time-icon"><Icon name="clock" size={16} /></span>
              <span class="time">{t.sundayTime}</span>
            </div>
            <p class="service-desc">{t.sundayDesc}</p>
            <div class="service-features">
              <span><Icon name="hands" size={16} /> Praise & Worship</span>
              <span><Icon name="book" size={16} /> Word Ministry</span>
              <span><Icon name="handshake" size={16} /> Fellowship</span>
            </div>
          </div>
          <div class="card-footer">
            <a href="#location" class="btn-service"><Icon name="map-pin" size={16} /> {lang === 'en' ? 'Find Location' : 'Локација'}</a>
          </div>
        </div>

        <!-- Wednesday Service -->
        <div class="service-card wednesday">
          <div class="card-header" style="background: #04872d">
            <span class="day-icon"><Icon name="hands" size={20} /></span>
            <h3>{t.wednesdayService}</h3>
          </div>
          <div class="card-body">
            <div class="time-badge" style="color: #04872d">
              <span class="time-icon"><Icon name="clock" size={16} /></span>
              <span class="time">{t.wednesdayTime}</span>
            </div>
            <p class="service-desc">{t.wednesdayDesc}</p>
            <div class="service-features">
              <span><Icon name="fire" size={16} /> Fervent Prayer</span>
              <span><Icon name="book" size={16} /> Bible Reading</span>
              <span><Icon name="message" size={16} /> Testimonies</span>
            </div>
          </div>
          <div class="card-footer">
            <a href="#location" class="btn-service"><Icon name="map-pin" size={16} /> {lang === 'en' ? 'Find Location' : 'Локација'}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Prayer & Worship Section (RCCG Focus) -->
  <section class="prayer-section">
    <div class="container">
      <div class="prayer-grid">
        <div class="prayer-content">
          <div class="section-badge" style="background: #d30c07"><Icon name="fire" size={16} /> RCCG PRAYER</div>
          <h2>{t.prayerTitle}</h2>
          <p class="prayer-description">{t.prayerDesc}</p>
          <p class="worship-description">{t.worshipDesc}</p>
          
          <div class="prayer-features">
            <div class="feature">
              <span class="feature-icon"><Icon name="fire" size={22} /></span>
              <div>
                <h4>{lang === 'en' ? 'Fervent Prayer' : 'Усрдна молитва'}</h4>
                <p>{lang === 'en' ? 'Experience the power of corporate prayer' : 'Доживејте ја силата на заедничката молитва'}</p>
              </div>
            </div>
            <div class="feature">
              <span class="feature-icon"><Icon name="music" size={22} /></span>
              <div>
                <h4>{lang === 'en' ? 'Hearty Worship' : 'Искрено богослужение'}</h4>
                <p>{lang === 'en' ? 'Lift your voice in praise and worship' : 'Подгни го својот глас во пофалба и богослужение'}</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="prayer-image">
          <ScriptureVerseImage lang={lang} />
        </div>
      </div>
    </div>
  </section>

  <!-- Worship Gallery -->
  <WorshipGallery lang={lang} />

  <!-- Location Map -->
  <LocationMap lang={lang} />

  <!-- Connect with Pastor CTA -->
  <section class="pastor-cta" style="background: linear-gradient(135deg, #26146d, #04872d)">
    <div class="container">
      <div class="cta-content">
        <span class="cta-icon"><Icon name="heart" size={26} /></span>
        <h2>{lang === 'en' ? 'Connect with Our Pastor' : 'Контактирајте го нашиот пастор'}</h2>
        <p>
          {lang === 'en' 
            ? 'Have questions? Need prayer? Want to know more about RCCG Love Assembly?' 
            : 'Имате прашања? Потреба од молитва? Сакате да дознаете повеќе за RCCG Љубов Собрание?'}
        </p>
        <a 
          href="https://wa.me/38978915445?text=Hello%20Pastor%2C%20I%27d%20like%20to%20know%20more%20about%20RCCG%20Love%20Assembly%20Macedonia" 
          class="whatsapp-cta-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="btn-icon"><Icon name="message" size={20} /></span>
          <span class="btn-text">{t.whatsappButton}</span>
        </a>
        <p class="pastor-note">
          {lang === 'en' ? 'Pastor Fola will respond as soon as possible' : 'Пастор Фола ќе одговори што е можно побрзо'}
        </p>
      </div>
    </div>
  </section>

  <!-- WhatsApp Floating Button -->
  <WhatsAppButton lang={lang} phoneNumber="38978915445" />

</Layout>

<style>
  /* Welcome Section Styles */
  .welcome-section {
    padding: 5rem 0;
    background: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .welcome-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .section-tag {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .rccg-tag {
    background: #26146d;
    color: white;
    padding: 0.3rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .region-tag {
    background: #04872d;
    color: white;
    padding: 0.3rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .country-tag {
    background: #d30c07;
    color: white;
    padding: 0.3rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .welcome-content h2 {
    font-size: 2.5rem;
    color: #333;
    margin-bottom: 1.5rem;
  }

  .highlight {
    color: #26146d;
    position: relative;
    display: inline-block;
  }

  .highlight::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, #04872d, #d30c07);
    border-radius: 2px;
  }

  .welcome-text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #555;
    margin-bottom: 2rem;
  }

  .rccg-values {
    display: grid;
    grid-template-columns: repeat(2, minmax(180px, 1fr));
    gap: 1rem;
  }

  .value-item {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1rem 1.1rem;
    background: #f8f9fa;
    border-radius: 10px;
    transition: transform 0.3s;
  }

  .value-item:hover {
    transform: translateX(5px);
    background: linear-gradient(135deg, #f8f9fa, #e9ecef);
  }

  .value-icon {
    font-size: 1.75rem;
  }

  .value-item span:not(.value-icon) {
    font-size: 1.05rem;
    font-weight: 600;
  }

  .welcome-image {
    position: relative;
  }

  .featured-image {
    width: 100%;
    height: auto;
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  .image-overlay-badge {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: min(92%, 420px);
    background: white;
    padding: 1.5rem;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    text-align: center;
  }

  .badge-text {
    display: block;
    font-size: 1.2rem;
    font-weight: bold;
    color: #26146d;
    margin-bottom: 0.3rem;
  }

  .badge-location {
    color: #04872d;
    font-size: 0.9rem;
  }

  /* Services Section */
  .services-section {
    padding: 5rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    color: #26146d;
    margin: 0 0 1rem;
    position: relative;
    display: inline-block;
  }

  .section-header h2::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, #04872d, #d30c07);
  }

  .section-subtitle {
    font-size: 1.2rem;
    color: #666;
    max-width: 600px;
    margin: 2rem auto 0;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    align-items: stretch;
  }

  .service-card {
    background: white;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    transition: transform 0.3s;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .service-card:hover {
    transform: translateY(-10px);
  }

  .card-header {
    padding: 1.5rem;
    text-align: center;
    color: white;
  }

  .day-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .card-header h3 {
    margin: 0;
    font-size: 1.1rem;
  }

  .card-body {
    padding: 1.5rem;
    flex: 1;
  }

  .time-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 1.3rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }

  .service-desc {
    color: #666;
    font-size: 0.95rem;
    text-align: center;
    margin-bottom: 1rem;
    min-height: 60px;
  }

  .service-features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .service-features span {
    background: #f0f0f0;
    padding: 0.3rem 0.8rem;
    border-radius: 15px;
    font-size: 0.8rem;
    color: #555;
  }

  .card-footer {
    padding: 1rem 1.5rem 1.5rem;
    text-align: center;
  }

  .btn-service {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: #f8f9fa;
    color: #26146d;
    text-decoration: none;
    border-radius: 25px;
    font-size: 0.9rem;
    transition: all 0.3s;
  }

  .btn-service:hover {
    background: #26146d;
    color: white;
  }

  /* Prayer Section */
  .prayer-section {
    padding: 5rem 0;
    background: white;
  }

  .prayer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .section-badge {
    display: inline-block;
    padding: 0.3rem 1rem;
    color: white;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .prayer-content h2 {
    font-size: 2.5rem;
    color: #26146d;
    margin-bottom: 1.5rem;
  }

  .prayer-description, .worship-description {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #555;
    margin-bottom: 1.5rem;
  }

  .prayer-features {
    margin-top: 2rem;
  }

  .feature {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .feature-icon {
    font-size: 2rem;
    min-width: 50px;
  }

  .feature h4 {
    color: #26146d;
    margin-bottom: 0.3rem;
  }

  .feature p {
    color: #666;
  }

  .prayer-image {
    position: relative;
  }

  .prayer-image img {
    width: 100%;
    height: auto;
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  .image-quote {
    position: absolute;
    bottom: -20px;
    right: -20px;
    background: #d30c07;
    color: white;
    padding: 1.5rem;
    border-radius: 10px;
    max-width: 250px;
    font-size: 1.1rem;
    font-style: italic;
    box-shadow: 0 10px 30px rgba(211,12,7,0.3);
  }

  .image-quote span {
    display: block;
    font-size: 0.9rem;
    margin-top: 0.5rem;
    opacity: 0.9;
  }

  /* Pastor CTA */
  .pastor-cta {
    padding: 5rem 0;
    color: white;
    text-align: center;
  }

  .cta-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: 1rem;
  }

  .pastor-cta h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .pastor-cta p {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .whatsapp-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: #25d366;
    color: white;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    text-decoration: none;
    font-size: 1.2rem;
    font-weight: 600;
    transition: transform 0.3s, box-shadow 0.3s;
    box-shadow: 0 4px 15px rgba(37,211,102,0.3);
  }

  .whatsapp-cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(37,211,102,0.4);
  }

  .btn-icon {
    font-size: 1.5rem;
  }

  .pastor-note {
    margin-top: 1rem;
    font-size: 0.9rem !important;
    opacity: 0.8 !important;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .welcome-grid,
    .prayer-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .welcome-content,
    .prayer-content,
    .service-card,
    .cta-content {
      text-align: center;
    }

    .welcome-text,
    .prayer-description,
    .worship-description,
    .section-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .rccg-values {
      grid-template-columns: 1fr;
      justify-items: center;
      width: 100%;
      max-width: 460px;
      margin-left: auto;
      margin-right: auto;
    }

    .value-item {
      width: 100%;
    }

    .value-item,
    .feature,
    .service-features span {
      justify-content: center;
      text-align: center;
    }

    .section-tag {
      justify-content: center;
      flex-wrap: wrap;
    }

    .welcome-content {
      order: 2;
    }

    .welcome-image {
      order: 1;
    }

    .service-grid {
      grid-template-columns: 1fr;
    }

    .section-header h2 {
      font-size: 2rem;
    }

    .prayer-content h2 {
      font-size: 2rem;
    }

    .image-quote {
      right: 0;
      max-width: 200px;
      padding: 1rem;
    }
  }

  @media (max-width: 480px) {
    .container {
      padding: 0 1rem;
    }

    .rccg-values {
      grid-template-columns: 1fr;
    }

    .image-overlay-badge {
      position: relative;
      bottom: 0;
      margin-top: 1rem;
      left: auto;
      transform: none;
      width: 100%;
      max-width: 420px;
      margin-left: auto;
      margin-right: auto;
    }

    .image-quote {
      position: relative;
      bottom: 0;
      right: 0;
      margin-top: 1rem;
      max-width: 100%;
    }
  }
</style>
