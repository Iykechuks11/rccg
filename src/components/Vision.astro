---
// src/components/Vision.astro
import { translations } from '../i18n/translations';
import Icon from './Icon.astro';

const { lang } = Astro.props;
const t = translations[lang];
---

<section class="vision-section" id="vision">
  <div class="container">
    <div class="section-header">
      <span class="section-icon">
        <Icon name="globe" size={54} />
      <h2>{t.visionTitle}</h2>
      <p class="section-subtitle">{t.visionSubtitle}</p>
      </span>
    </div>

    <div class="vision-content">
      <p class="vision-intro">{t.visionIntro}</p>

      <div class="vision-timeline">
        {t.visionList.map((item) => (
          <div class="vision-item">
            <div class="vision-number" style={`background: ${item.number === 1 ? '#d30c07' : item.number === 6 ? '#26146d' : '#04872d'}`}>
              <span class="number">{item.number}</span>
            </div>
            <div class="vision-text">
              <p class="vision-point">{item.text}</p>
              <span class="vision-emphasis">{item.emphasis}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="vision-quote">
        <div class="quote-icon">"</div>
        <p class="quote-text">{t.visionQuote}</p>
        <div class="quote-footer">
          <span class="quote-author">— RCCG</span>
        </div>
      </div>

      <div class="vision-footer">
        <p>{t.visionFooter}</p>
        <div class="vision-mandate">
          <span class="mandate-icon"><Icon name="globe" size={20} /></span>
          <span class="mandate-text">Matthew 28:19-20</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .vision-section {
    padding: 6rem 0;
    background: linear-gradient(135deg, #f5f7fa 0%, #ffffff 100%);
    position: relative;
    overflow: hidden;
  }

  .vision-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(4,135,45,0.03) 0%, transparent 70%);
    border-radius: 50%;
  }

  .vision-section::after {
    content: '';
    position: absolute;
    bottom: -20%;
    left: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(211,12,7,0.03) 0%, transparent 70%);
    border-radius: 50%;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 2;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: 1rem;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
  }

  .section-header h2 {
    font-size: 3rem;
    color: #26146d;
    margin: 0 0 1rem;
    position: relative;
    display: inline-block;
    font-weight: 800;
  }

  .section-header h2::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 4px;
    background: linear-gradient(90deg, #04872d, #d30c07, #26146d);
    border-radius: 2px;
  }

  .section-subtitle {
    font-size: 1.3rem;
    color: #04872d;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .vision-content {
    max-width: 900px;
    margin: 0 auto;
  }

  .vision-intro {
    font-size: 1.2rem;
    line-height: 1.8;
    color: #555;
    text-align: center;
    margin-bottom: 4rem;
    padding: 2rem;
    background: white;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border-left: 5px solid #d30c07;
  }

  .vision-timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 4rem;
    position: relative;
  }

  .vision-timeline::before {
    content: '';
    position: absolute;
    left: 40px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #04872d, #d30c07, #26146d);
    opacity: 0.3;
  }

  .vision-item {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    position: relative;
    background: white;
    padding: 2rem;
    border-radius: 15px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    transition: all 0.3s;
    border: 1px solid rgba(0,0,0,0.05);
  }

  .vision-item:hover {
    transform: translateX(10px);
    box-shadow: 0 15px 40px rgba(38,20,109,0.1);
    border-color: rgba(4,135,45,0.2);
  }

  .vision-number {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.8rem;
    font-weight: bold;
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  .number {
    position: relative;
    z-index: 2;
  }

  .vision-text {
    flex: 1;
  }

  .vision-point {
    font-size: 1.2rem;
    color: #333;
    margin-bottom: 0.5rem;
    line-height: 1.6;
    font-weight: 500;
  }

  .vision-emphasis {
    display: inline-block;
    background: linear-gradient(135deg, #f5f7fa, #e9ecef);
    padding: 0.3rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    color: #26146d;
    font-weight: 600;
    border: 1px solid rgba(4,135,45,0.2);
  }

  .vision-quote {
    background: linear-gradient(135deg, #26146d, #1a0f4a);
    color: white;
    padding: 3rem;
    border-radius: 20px;
    margin: 3rem 0;
    position: relative;
    text-align: center;
    box-shadow: 0 20px 40px rgba(38,20,109,0.3);
  }

  .quote-icon {
    position: absolute;
    top: 20px;
    left: 30px;
    font-size: 6rem;
    opacity: 0.2;
    font-family: Georgia, serif;
  }

  .quote-text {
    font-size: 1.4rem;
    line-height: 1.8;
    font-style: italic;
    max-width: 700px;
    margin: 0 auto 1rem;
    position: relative;
  }

  .quote-footer {
    margin-top: 1rem;
  }

  .quote-author {
    font-size: 1.1rem;
    opacity: 0.9;
    letter-spacing: 2px;
  }

  .vision-footer {
    text-align: center;
    padding: 2rem;
    background: white;
    border-radius: 15px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    border: 2px solid #04872d;
  }

  .vision-footer p {
    font-size: 1.3rem;
    color: #26146d;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .vision-mandate {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
  }

  .mandate-icon {
    font-size: 1.8rem;
  }

  .mandate-text {
    font-size: 1.1rem;
    color: #04872d;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .section-header h2 {
      font-size: 2.2rem;
    }

    .vision-timeline::before {
      left: 30px;
    }

    .vision-item {
      flex-direction: column;
      gap: 1rem;
      padding: 1.5rem;
    }

    .vision-number {
      width: 50px;
      height: 50px;
      font-size: 1.5rem;
    }

    .vision-point {
      font-size: 1.1rem;
    }

    .quote-text {
      font-size: 1.2rem;
    }

    .vision-footer p {
      font-size: 1.1rem;
    }
  }

  @media (max-width: 480px) {
    .vision-intro {
      font-size: 1rem;
      padding: 1.5rem;
    }

    .vision-quote {
      padding: 2rem;
    }

    .quote-text {
      font-size: 1rem;
    }
  }
</style>
