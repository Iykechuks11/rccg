---
// src/components/LocationMap.astro
import { translations } from '../i18n/translations';
import Icon from './Icon.astro';

const { lang } = Astro.props;
const t = translations[lang];
// Google Maps embed URL for DSC DESIGN dooel, Skopje
const mapEmbedUrl = "https://www.google.com/maps/embed?pb=!1m23!1m12!1m3!1d23717.40909877547!2d21.39853565!3d42.0072256!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!4m8!3e6!4m0!4m5!1s0x13541565a32cb94f%3A0x20e72596a21cb33!2sDSC%20DIZAJN%20dooel%20-%20Skopje%2C%20Kosturski%20Heroi%206%2F2%2C%20Skopje%201000!3m2!1d42.001106899999996!2d21.418037899999998!5e0!3m2!1sen!2smk!4v1771419356657!5m2!1sen!2smk";
---

<section class="location-section" id="location">
  <div class="container">
    <div class="section-header">
      <span class="section-icon"><Icon name="map-pin" size={44} /></span>
      <h2>{t.location}</h2>
      <p class="section-subtitle">DSC DESIGN dooel, Skopje, North Macedonia</p>
    </div>
    
    <div class="location-grid">
      <div class="location-info">
        <div class="address-card">
          <h3>{lang === 'en' ? 'Visit Us' : 'Посетете не'}</h3>
          <div class="address-details">
            <div class="address-line">
              <span class="icon"><Icon name="map-pin" size={24} /></span>
              <div>
                <strong>DSC DESIGN dooel</strong>
                <p>Skopje, North Macedonia</p>
              </div>
            </div>
            
            <div class="transport-info">
              <h4>{lang === 'en' ? 'Getting Here' : 'Како да стигнете'}</h4>
              <div class="transport-item">
                <span><Icon name="walk" size={20} /></span>
                <span>{lang === 'en' ? '5 min walk from Macedonia Square' : '5 мин пеш од Плоштад Македонија'}</span>
              </div>
              <div class="transport-item">
                <span><Icon name="bus" size={20} /></span>
                <span>{lang === 'en' ? 'Bus stops: 2, 5, 15, 50' : 'Автобуски станици: 2, 5, 15, 50'}</span>
              </div>
              <div class="transport-item">
                <span><Icon name="car" size={20} /></span>
                <span>{lang === 'en' ? 'Street parking available' : 'Паркинг на улица'}</span>
              </div>
            </div>
          </div>
          
          <a 
            href="https://maps.google.com/?q=DSC+DESIGN+dooel+Skopje" 
            target="_blank" 
            rel="noopener noreferrer"
            class="directions-btn"
          >
            <span><Icon name="directions" size={18} /></span>
            {t.getDirections}
          </a>
        </div>
        
        <div class="service-reminder">
          <h4>{t.serviceTimes}</h4>
          <div class="reminder-times">
            <div><span>{t.sundaySchool}:</span> <strong>{t.sundaySchoolTime}</strong></div>
            <div><span>{t.sundayService}:</span> <strong>{t.sundayTime}</strong></div>
            <div><span>{t.wednesdayService}:</span> <strong>{t.wednesdayTime}</strong></div>
          </div>
        </div>
      </div>
      
      <div class="map-container">
        <iframe 
          src={mapEmbedUrl}
          width="100%" 
          height="450" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="RCCG Love Assembly Location - DSC DESIGN dooel, Skopje"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .location-section {
    padding: 5rem 0;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .section-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
  }
  
  .section-header h2 {
    font-size: 2.5rem;
    color: #26146d;
    margin: 0 0 1rem;
    position: relative;
    display: inline-block;
  }
  
  .section-header h2::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, #04872d, #d30c07);
  }
  
  .section-subtitle {
    font-size: 1.2rem;
    color: #666;
  }
  
  .location-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 2rem;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    background: white;
  }
  
  .location-info {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  
  .address-card h3 {
    color: #26146d;
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }
  
  .address-details {
    margin-bottom: 1.5rem;
  }
  
  .address-line {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  
  .icon {
    font-size: 1.5rem;
  }
  
  .address-line strong {
    display: block;
    font-size: 1.2rem;
    color: #333;
  }
  
  .address-line p {
    color: #666;
    margin: 0.3rem 0 0;
  }
  
  .transport-info h4 {
    color: #04872d;
    margin-bottom: 1rem;
  }
  
  .transport-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.8rem;
    color: #555;
  }
  
  .directions-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    background: linear-gradient(135deg, #26146d, #04872d);
    color: white;
    padding: 1rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
    width: 100%;
    justify-content: center;
  }
  
  .directions-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(38,20,109,0.3);
  }
  
  .service-reminder {
    background: linear-gradient(135deg, #26146d10, #04872d10);
    padding: 1.5rem;
    border-radius: 10px;
    border: 1px solid rgba(38,20,109,0.1);
  }
  
  .service-reminder h4 {
    color: #d30c07;
    margin-bottom: 1rem;
  }
  
  .reminder-times {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .reminder-times div {
    display: flex;
    justify-content: space-between;
    padding: 0.3rem 0;
    border-bottom: 1px dashed rgba(0,0,0,0.1);
  }
  
  .reminder-times strong {
    color: #26146d;
  }
  
  .map-container {
    position: relative;
    min-height: 450px;
  }
  
  .map-container iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  @media (max-width: 768px) {
    .location-grid {
      grid-template-columns: 1fr;
    }
    
    .map-container {
      min-height: 350px;
    }
    
    .section-header h2 {
      font-size: 2rem;
    }
  }
</style>
