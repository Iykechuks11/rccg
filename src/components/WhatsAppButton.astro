---
// src/components/WhatsAppButton.astro
const { lang, phoneNumber = "38978915445" } = Astro.props;
const message = lang === 'en' 
  ? "Hello Pastor Fola, I'd like to know more about RCCG Love Assembly Macedonia" 
  : "Здраво Пастор Фола, сакам да дознаам повеќе за RCCG Љубов Собрание Македонија";
const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
---

<div class="whatsapp-float">
  <a 
    href={whatsappUrl} 
    class="whatsapp-button" 
    target="_blank" 
    rel="noopener noreferrer"
    aria-label="Chat on WhatsApp"
  >
    <div class="whatsapp-icon">
      <svg viewBox="0 0 24 24" width="32" height="32">
        <path fill="#fff" d="M19.077 4.928C17.191 3.041 14.683 2 12.006 2 6.798 2 2.548 6.193 2.54 11.393c-.003 1.747.456 3.457 1.328 4.984L2.25 21.75l5.428-1.568c1.473.839 3.135 1.287 4.84 1.29h.004c5.198 0 9.456-4.195 9.464-9.396.004-2.513-.974-4.88-2.86-6.768zM12.014 20.02h-.003c-1.496-.002-2.964-.408-4.247-1.175l-.305-.182-3.295.952 1.027-3.174-.189-.312c-.835-1.355-1.278-2.92-1.276-4.53.008-4.259 3.47-7.715 7.737-7.715 2.062 0 4 .806 5.456 2.268 1.455 1.46 2.256 3.398 2.252 5.456-.008 4.26-3.47 7.712-7.725 7.712zM16.11 13.83c-.226-.113-1.335-.658-1.542-.733-.206-.075-.357-.113-.507.113-.15.225-.584.733-.715.883-.132.15-.263.17-.489.056-.862-.426-1.496-.783-2.116-1.316-.608-.523-1.018-1.127-1.138-1.317-.12-.19-.013-.293.09-.388.093-.084.206-.225.308-.338.103-.112.137-.188.206-.313.068-.126.034-.236-.017-.33-.052-.094-.47-1.124-.642-1.535-.168-.398-.338-.33-.465-.337-.134-.007-.27-.008-.406-.008-.226 0-.45.054-.626.225-.38.338-.963.937-.963 2.27 0 1.33.97 2.618 1.105 2.8.135.18 1.86 2.962 4.59 4.03.636.248 1.16.424 1.586.55.64.188 1.174.17 1.628.084.526-.1 1.335-.546 1.523-1.07.188-.525.188-.975.132-1.07-.056-.094-.207-.15-.433-.264z"/>
      </svg>
    </div>
    <div class="whatsapp-tooltip">
      {lang === 'en' ? 'Connect with Pastor Fola' : 'Поврзете се со Пастор Фола'}
    </div>
  </a>
</div>

<style>
  .whatsapp-float {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 1000;
  }
  
  .whatsapp-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #25d366, #128C7E);
    border-radius: 50%;
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.3);
    transition: all 0.3s ease;
    cursor: pointer;
    position: relative;
    animation: pulse 2s infinite;
  }
  
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.7);
    }
    70% {
      box-shadow: 0 0 0 15px rgba(37, 211, 102, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0);
    }
  }
  
  .whatsapp-button:hover {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 8px 25px rgba(37, 211, 102, 0.4);
    animation: none;
  }
  
  .whatsapp-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .whatsapp-tooltip {
    position: absolute;
    right: 70px;
    background: white;
    color: #075e54;
    padding: 8px 15px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    white-space: nowrap;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    pointer-events: none;
  }
  
  .whatsapp-button:hover .whatsapp-tooltip {
    opacity: 1;
    visibility: visible;
    right: 80px;
  }
  
  @media (max-width: 768px) {
    .whatsapp-float {
      bottom: 20px;
      right: 20px;
    }
    
    .whatsapp-tooltip {
      display: none;
    }
  }
</style>
