---
// src/components/Footer.astro
import { translations } from '../i18n/translations';
import Icon from './Icon.astro';
import Image from 'astro/components/Image.astro';
import logo from '../assets/rccg-for-web.png'

const { lang } = Astro.props;
const t = translations[lang];
const currentYear = new Date().getFullYear();
const homePath = lang === 'en' ? '/' : `/${lang}`;

const socialLinks = [
  { name: 'Facebook', icon: 'facebook', url: 'https://facebook.com/rccgloveassembly', color: '#1877f2' },
  { name: 'Instagram', icon: 'instagram', url: 'https://instagram.com/rccgloveassembly', color: '#e4405f' },
  { name: 'YouTube', icon: 'youtube', url: 'https://youtube.com/rccgloveassembly', color: '#ff0000' },
  { name: 'WhatsApp', icon: 'whatsapp', url: 'https://wa.me/38978915445', color: '#25d366' }
];
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-grid">
      
      <!-- Column 1: Church Info -->
      <div class="footer-col">
        <a href={lang === 'en' ? '/' : `/${lang}`} class="logo-link">
          <Image 
            src={logo} 
            alt="RCCG Love Assembly Logo" 
            class="logo-image"
            width={120}
            height={60}
            format="png"
          />
        </a>
        <p class="church-description">
          {lang === 'en' 
            ? 'A parish of the Redeemed Christian Church of God in the Balkan Region, North Macedonia. Making heaven and taking as many people as possible with us.'
            : 'Парохија на Искупената Христијанска Црква Божја во Балканскиот Регион, Северна Македонија. Да стигнеме до рајот и да земеме што повеќе луѓе со нас.'
          }
        </p>
        
        <div class="quick-contact">
          <div class="contact-item">
            <span class="contact-icon"><Icon name="map-pin" size={18} /></span>
            <span>DSC DESIGN dooel, Skopje</span>
          </div>
          <div class="contact-item">
            <span class="contact-icon"><Icon name="phone" size={18} /></span>
            <span>+389 789 15 445</span>
          </div>
          <div class="contact-item">
            <span class="contact-icon"><Icon name="mail" size={18} /></span>
            <span>rccgloveassemblymk@gmail.com</span>
          </div>
        </div>
      </div>
      
      <!-- Column 2: Quick Links -->
      <div class="footer-col">
        <h3 class="footer-title">
          <span class="title-icon"><Icon name="link" size={20} /></span>
          {t.quickLinks}
        </h3>
        <ul class="footer-links">
          <li><a href={homePath}>{t.navHome}</a></li>
          <li><a href={lang === 'en' ? '/about' : `/${lang}/about`}>{t.navAbout}</a></li>
          <li><a href={`${homePath}#services`}>{t.navServices}</a></li>
          <li><a href={`${homePath}#gallery`}>{t.navGallery}</a></li>
          <li><a href={`${homePath}#location`}>{t.navContact}</a></li>
        </ul>
      </div>
      
      <!-- Column 3: Service Times -->
      <div class="footer-col">
        <h3 class="footer-title">
          <span class="title-icon"><Icon name="clock" size={20} /></span>
          {t.serviceTimes}
        </h3>
        <ul class="service-schedule">
          <li>
            <span class="service-day">{t.sundaySchool}</span>
            <span class="service-time-badge">{t.sundaySchoolTime}</span>
          </li>
          <li>
            <span class="service-day">{t.sundayService}</span>
            <span class="service-time-badge">{t.sundayTime}</span>
          </li>
          <li>
            <span class="service-day">{t.wednesdayService}</span>
            <span class="service-time-badge">{t.wednesdayTime}</span>
          </li>
        </ul>
      </div>
      
      <!-- Column 4: Connect -->
      <div class="footer-col">
        <h3 class="footer-title">
          <span class="title-icon"><Icon name="mail" size={20} /></span>
          {t.connectWithUs}
        </h3>
        
        <!-- Social Media Links -->
        <div class="social-links">
          {socialLinks.map(link => (
            <a 
              href={link.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="social-link"
              style={`background-color: ${link.color}`}
              title={link.name}
            >
              <span class="social-icon"><Icon name={link.icon} size={20} /></span>
            </a>
          ))}
        </div>
        
        <div class="footer-note">
          <p>RCCG Love Assembly</p>
          <p>Balkan Region, North Macedonia</p>
        </div>
      </div>
    </div>
    
    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <div class="copyright">
        {t.copyright.replace('{year}', currentYear).replace('{churchName}', t.churchName)}
      </div>
      
      <div class="footer-bottom-links">
        <a href={`${homePath}#about`}>{t.privacyPolicy}</a>
        <a href={`${homePath}#vision`}>{t.termsOfUse}</a>
        <a href={`${homePath}#location`}>{t.navContact}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: #fff;
    padding: 4rem 0 0;
    margin-top: 4rem;
    position: relative;
    overflow: hidden;
  }
  
  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #26146d, #04872d, #d30c07, #ffffff);
  }
  
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
    margin-bottom: 3rem;
  }
  
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .footer-title {
    font-size: 1.3rem;
    margin-bottom: 1rem;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 2px solid rgba(255,255,255,0.1);
    padding-bottom: 0.5rem;
  }
  
  .title-icon, .church-icon {
    font-size: 1.5rem;
  }
  
  .church-description {
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }
  
  .quick-contact {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  
  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }
  
  .contact-icon {
    font-size: 1.2rem;
    min-width: 24px;
  }
  
  .footer-links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  
  .footer-links a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: all 0.3s;
    display: inline-block;
  }
  
  .footer-links a:hover {
    color: #fff;
    transform: translateX(5px);
  }
  
  .service-schedule {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .service-schedule li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .service-day {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }
  
  .service-time-badge {
    background: rgba(255,255,255,0.1);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.85rem;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.2);
  }
  
  .social-links {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  
  .social-link {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: transform 0.3s;
  }
  
  .social-link:hover {
    transform: translateY(-5px);
  }
  
  .social-icon {
    font-size: 1.2rem;
  }
  
  .footer-note {
    color: rgba(255,255,255,0.6);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 2rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .copyright {
    color: rgba(255,255,255,0.6);
    font-size: 0.9rem;
  }
  
  .footer-bottom-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }
  
  .footer-bottom-links a {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s;
  }
  
  .footer-bottom-links a:hover {
    color: #fff;
  }
  
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 768px) {
    .footer {
      padding: 3rem 0 0;
    }
    
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
    
    .footer-bottom-links {
      justify-content: center;
    }
  }
</style>
